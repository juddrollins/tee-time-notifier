# Copy to secret.yaml and fill in real values. Do NOT commit secret.yaml.
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your regular password.
apiVersion: v1
kind: Secret
metadata:
  name: tee-time-secrets
  namespace: argo
type: Opaque
stringData:
  SMTP_USER: "you@gmail.com"
  SMTP_PASS: "your-app-password"
  NOTIFY_EMAILS: "you@gmail.com,friend@gmail.com"
  GITHUB_TOKEN: "ghp_your-personal-access-token"
  GITHUB_OWNER: "your-github-username"
  GITHUB_REPO: "your-repo-name"
